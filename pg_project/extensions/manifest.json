{
  "version": "1.0",
  "description": "지원 extension 카탈로그. pg_download.sh가 이 목록을 참조해 rpm을 다운로드합니다.",
  "extensions": {
    "pg_stat_statements": {
      "description": "쿼리 실행 통계 수집 (PostgreSQL contrib 내장)",
      "rpm_pattern": null,
      "contrib": true,
      "note": "postgresql-contrib 패키지에 포함"
    },
    "pgaudit": {
      "description": "감사(audit) 로그",
      "rpm_pattern": "pgaudit*${PG_MAJOR}*",
      "contrib": false
    },
    "pg_stat_monitor": {
      "description": "확장 쿼리 통계 수집",
      "rpm_pattern": "pg_stat_monitor_${PG_MAJOR}*",
      "contrib": false
    },
    "pg_cron": {
      "description": "DB 내부 크론 스케줄러",
      "rpm_pattern": "pg_cron_${PG_MAJOR}*",
      "contrib": false
    }
  }
}
